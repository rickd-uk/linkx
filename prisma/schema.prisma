generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  icon        String   @default("📁")  // Emoji icon for the category
  isPublic    Boolean  @default(false)  // Admin categories are public, user categories are private
  createdById String?  // null = admin created
  createdBy   User?    @relation("UserCategories", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([createdById])
}

model Link {
  id          String   @id @default(cuid())
  title       String
  url         String
  description String?
  category    String?
  author      String?  @default("Unknown Author")
  timestamp   DateTime @default(now())
  publicationDay   Int?    // Day (1-31)
  publicationMonth Int?    // Month (1-12)
  publicationYear  Int?    // Year (ex. 2025)
  boost       Float    @default(1.0)  // Admin multiplier for hot score
  isPublic    Boolean  @default(false)  // Admin links are public, user links are private
  createdById String?  // null = admin created
  createdBy   User?    @relation("UserLinks", fields: [createdById], references: [id], onDelete: SetNull)
  deletedAt   DateTime? // null = active, set = soft-deleted (in recycle bin)
  votes       Vote[]
  archives    ArchivedLink[]

  @@index([category])
  @@index([createdById])
  @@index([isPublic])
  @@index([deletedAt])
}

model ArchivedLink {
  id         String   @id @default(cuid())
  linkId     String
  userId     String
  archivedAt DateTime @default(now())

  link       Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([linkId, userId])
  @@index([userId])
  @@index([linkId])
  @@index([archivedAt])
}

model Vote {
  id        String   @id @default(cuid())
  linkId    String
  userId    String   // References User.id (authenticated users only)
  count     Int      @default(1)  // 1-3 votes
  createdAt DateTime @default(now())

  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([linkId, userId])
  @@index([userId])
  @@index([linkId])
}

model User {
  id            String     @id @default(cuid())
  username      String     @unique
  email         String?    @unique
  passwordHash  String
  preferences   String     @default("{}") // JSON: user UI preferences
  isTestUser    Boolean    @default(false) // true = generated test/dummy user
  lastSeenAt    DateTime?  // updated on each auth/me check
  bannedUntil   DateTime?  // null = not banned; future date = banned until then
  forceLogoutAt DateTime?  // tokens issued before this time are invalid
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  votes         Vote[]
  links         Link[]     @relation("UserLinks")
  categories    Category[] @relation("UserCategories")
  archives      ArchivedLink[]

  @@index([email])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
